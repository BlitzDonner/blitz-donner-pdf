{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bdpdf/flipbook",
	"version": "0.6.1",
	"title": "BD PDF",
	"category": "media",
	"icon": "book",
	"description": "Zeigt ein PDF aus der Mediathek als blätterbares Buch mit Umblätter-Animation.",
	"keywords": [
		"pdf",
		"flipbook",
		"blättern",
		"buch"
	],
	"textdomain": "blitz-donner-pdf",
	"attributes": {
		"pdfId": {
			"type": "number"
		},
		"pdfUrl": {
			"type": "string",
			"default": ""
		},
		"pdfTitle": {
			"type": "string",
			"default": ""
		},
		"showCover": {
			"type": "boolean",
			"default": true
		},
		"appearanceMode": {
			"type": "string",
			"default": "theme"
		},
		"pageLayout": {
			"type": "string",
			"default": "single"
		},
		"useDemo": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"align": [
			"wide",
			"full"
		],
		"html": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./editor.js",
	"editorStyle": "file:./editor.css",
	"script": [
		"file:./page-flip.browser.js",
		"file:./flipbook-core.js"
	],
	"style": "file:./view.css",
	"viewScriptModule": "file:./view.mjs",
	"example": {
		"attributes": {
			"useDemo": true
		},
		"viewportWidth": 900
	}
}
